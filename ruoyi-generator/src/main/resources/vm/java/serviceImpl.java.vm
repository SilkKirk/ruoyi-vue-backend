import com.mybatisflex.core.query.QueryWrapper;
import com.mybatisflex.core.paginate.Page;
import com.mybatisflex.spring.service.impl.ServiceImpl;
import ${packageName}.mapper.${ClassName}Mapper;
import ${packageName}.domain.${ClassName};
import ${packageName}.service.I${ClassName}Service;

/**
 * ${functionName}Service业务层处理
 * 
 * @author ${author}
 * @date ${datetime}
 */
@Service
public class ${ClassName}ServiceImpl extends ServiceImpl<${ClassName}Mapper, ${ClassName}> implements I${ClassName}Service
{
    /**
     * 查询${functionName}列表（不分页）
     * 
     * @param ${className} ${functionName}
     * @return ${functionName}
     */
    @Override
    public List<${ClassName}> selectList(${ClassName} ${className})
    {
        return mapper.selectListByQuery(buildQuery(${className}));
    }

    /**
     * 分页查询${functionName}列表
     * 
     * @param page 分页对象
     * @param ${className} ${functionName}
     * @return 分页结果
     */
    @Override
    public Page<${ClassName}> selectPage(Page<${ClassName}> page, ${ClassName} ${className})
    {
        return mapper.paginate(page, buildQuery(${className}));
    }

    /**
     * 构建查询条件
     */
    private QueryWrapper buildQuery(${ClassName} ${className})
    {
        QueryWrapper qw = QueryWrapper.create();
#foreach($column in $columns)
#if($column.query)
#if($column.queryType == "EQ")
        if (${className}.get${column.capJavaField}() != null) qw.eq(${ClassName}::get${column.capJavaField}, ${className}.get${column.capJavaField}());
#elseif($column.queryType == "NE")
        if (${className}.get${column.capJavaField}() != null) qw.ne(${ClassName}::get${column.capJavaField}, ${className}.get${column.capJavaField}());
#elseif($column.queryType == "GT")
        if (${className}.get${column.capJavaField}() != null) qw.gt(${ClassName}::get${column.capJavaField}, ${className}.get${column.capJavaField}());
#elseif($column.queryType == "GTE")
        if (${className}.get${column.capJavaField}() != null) qw.ge(${ClassName}::get${column.capJavaField}, ${className}.get${column.capJavaField}());
#elseif($column.queryType == "LT")
        if (${className}.get${column.capJavaField}() != null) qw.lt(${ClassName}::get${column.capJavaField}, ${className}.get${column.capJavaField}());
#elseif($column.queryType == "LTE")
        if (${className}.get${column.capJavaField}() != null) qw.le(${ClassName}::get${column.capJavaField}, ${className}.get${column.capJavaField}());
#elseif($column.queryType == "LIKE")
        if (${className}.get${column.capJavaField}() != null) qw.like(${ClassName}::get${column.capJavaField}, ${className}.get${column.capJavaField}());
#elseif($column.queryType == "BETWEEN")
        if (${className}.getParams().get("begin${column.capJavaField}") != null && ${className}.getParams().get("end${column.capJavaField}") != null)
            qw.between(${ClassName}::get${column.capJavaField}, ${className}.getParams().get("begin${column.capJavaField}"), ${className}.getParams().get("end${column.capJavaField}"));
#end
#end
#end
        return qw;
    }

#if($table.sub)
    /**
     * 新增${functionName}
     * 
     * @param ${className} ${functionName}
     * @return 结果
     */
    @Transactional
    @Override
    public boolean save(${ClassName} ${className})
    {
#foreach ($column in $columns)
#if($column.javaField == 'createTime')
        ${className}.setCreateTime(DateUtils.getNowDate());
#end
#end
        ${className}Mapper mapper = (${ClassName}Mapper) this.mapper;
        mapper.insertSelective(${className});
        insertSub(${className});
        return true;
    }

    /**
     * 修改${functionName}
     * 
     * @param ${className} ${functionName}
     * @return 结果
     */
    @Transactional
    @Override
    public boolean updateById(${ClassName} ${className})
    {
#foreach ($column in $columns)
#if($column.javaField == 'updateTime')
        ${className}.setUpdateTime(DateUtils.getNowDate());
#end
#end
        mapper.deleteByQuery(QueryWrapper.create().where(${subClassName}::get${subTableFkClassName}).eq(${className}.get${pkColumn.capJavaField}()));
        insertSub(${className});
        return super.updateById(${className});
    }

    /**
     * 新增${subTable.functionName}信息
     * 
     * @param ${className} ${functionName}对象
     */
    public void insertSub(${ClassName} ${className})
    {
        List<${subClassName}> ${subclassName}List = ${className}.get${subClassName}List();
        ${pkColumn.javaType} ${pkColumn.javaField} = ${className}.get${pkColumn.capJavaField}();
        if (StringUtils.isNotNull(${subclassName}List))
        {
            List<${subClassName}> list = new ArrayList<${subClassName}>();
            for (${subClassName} ${subclassName} : ${subclassName}List)
            {
                ${subclassName}.set${subTableFkClassName}(${pkColumn.javaField});
                list.add(${subclassName});
            }
            if (list.size() > 0)
            {
                mapper.insertBatch(list, list.size());
            }
        }
    }
#end
}
